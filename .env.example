# Anthropic API (Fable 5での総合判断・レポート生成に使用)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# J-Quants (日本株を使う場合のみ必要。米国株専用運用なら未設定でOK)
# https://jpx-jquants.com/ で無料登録後、https://jpx-jquants.com/dashboard/api-keys でAPIキーを発行
# (V2 APIはAPIキー認証。メール/パスワードでの認証は廃止済み)
JQUANTS_API_KEY=your_api_key

# mobile-dashboard (sync_report.py) でレポートを暗号化する際のパスフレーズ。
# スマホ側アプリでレポートを開くときも同じ値を入力する。
MOBILE_DASHBOARD_PASSWORD=change-me-to-a-real-passphrase
